# Vercel Postgres (auto-populated when you create a Vercel Postgres database)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Resend (for weekly email digest)
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=

# Email config
RESEND_FROM_EMAIL=PPC News <noreply@yourdomain.com>
DIGEST_EMAIL=info@zatomarketing.com

# Cron secret (set this in Vercel dashboard to secure cron endpoints)
CRON_SECRET=
