# Vercel Postgres (auto-populated when you create a Vercel Postgres database)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Mailchimp (recommended — creates a draft campaign each week for human review) ───
# The cron job creates a draft in your Mailchimp dashboard every Monday at 9am UTC.
# You review it and click Send manually.
# API key format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us19 (server prefix is after the dash)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=    # e.g. us19 — extracted automatically from API key if omitted
MAILCHIMP_LIST_ID=          # Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_FROM_NAME=ZATO Marketing
MAILCHIMP_FROM_EMAIL=info@zatomarketing.com

# ─── Resend (fallback if Mailchimp is not configured) ───
# Sign up at https://resend.com and create an API key
RESEND_API_KEY=
RESEND_FROM_EMAIL=PPC News <noreply@yourdomain.com>
DIGEST_EMAIL=info@zatomarketing.com

# ─── Cron secret ───
# Set this in Vercel dashboard to secure cron endpoints
CRON_SECRET=
